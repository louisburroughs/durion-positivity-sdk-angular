{
  "name": "@durion-sdk/transport",
  "version": "0.1.0-alpha",
  "description": "Shared transport configuration and HTTP client for Durion SDK",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "private": false,
  "scripts": {
    "build": "tsc && node -e \"const p=require('./package.json'),fs=require('fs');fs.writeFileSync('dist/package.json',JSON.stringify({name:p.name,version:p.version,description:p.description,main:'index.js',types:'index.d.ts',peerDependencies:p.peerDependencies},null,2)+'\\n')\"",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "@angular/core": "^21.0.0",
    "@angular/common": "^21.0.0",
    "rxjs": "^7.4.0"
  }
}
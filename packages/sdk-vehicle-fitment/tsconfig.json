{
    "compilerOptions": {
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "noImplicitAny": false,
        "target": "ES2022",
        "module": "ES2022",
        "moduleResolution": "bundler",
        "strictNullChecks": true,
        "removeComments": true,
        "sourceMap": true,
        "outDir": "./dist",
        "declaration": true,
        "lib": ["ES2022", "dom"],
        "typeRoots": [
            "node_modules/@types"
        ]
    },
    "exclude": [
        "node_modules",
        "dist"
    ]
}
